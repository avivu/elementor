{% set classes = ['e-con', 'e-atomic-element', base_styles.base] | merge(settings.classes | default([])) | join(' ') %}
{% set data_settings = {
	'source': settings.source,
	'autoplay': settings.autoplay,
	'mute': settings.mute,
	'loop': settings.loop,
	'start_time': settings.start_time,
	'end_time': settings.end_time,
	'play_on_mobile': settings.play_on_mobile,
	'privacy_mode': settings.privacy_mode,
	'fallback_image_url': settings.fallback_image.src | default(''),
} %}
<div class="{{ classes }} {{ editor_classes | default('') }}"
	data-id="{{ id }}"
	data-element_type="{{ type }}"
	data-e-type="{{ type }}"
	data-interaction-id="{{ interaction_id }}"
	data-interactions="{{ interactions | json_encode | e('html_attr') }}"
	data-settings="{{ data_settings | json_encode | e('html_attr') }}"
	style="display:flex; position:relative; overflow:hidden; width:100%; min-height:300px; padding:0;"
	{% if settings._cssid is defined and settings._cssid is not empty %}
		id="{{ settings._cssid | e('html_attr') }}"
	{% endif %}
	{% if settings.attributes is defined and settings.attributes is not empty %}
		{{ settings.attributes | raw }}
	{% endif %}
	{{ editor_attributes | default('') | raw }}>
	{% if settings.source is not empty %}
		{# Static preview: shown in editor and as initial placeholder on frontend.
		   JS hides this once the iframe is injected. #}
		<div class="e-bve-preview" aria-hidden="true"
			style="position:absolute; inset:0; z-index:0; background-color:#000;{% if settings.fallback_image is defined and settings.fallback_image.src is not empty %} background-image:url('{{ settings.fallback_image.src | e('full_url') }}'); background-size:cover; background-position:center;{% endif %}"></div>
	{% else %}
		{# Empty-state placeholder: visible only in the editor via CSS override. #}
		<div class="e-bve-empty" aria-hidden="true"
			style="position:absolute; inset:0; z-index:0; display:none; align-items:center; justify-content:center; background-color:#f5f5f5;">
			<svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
				<path d="M17.6902 8.92189C18.3227 8.56844 19.0991 8.58381 19.7162 8.96355L54.3829 30.2969C54.9738 30.661 55.3334 31.3059 55.3334 32C55.3334 32.6941 54.9738 33.339 54.3829 33.7031L19.7162 55.0365C19.0991 55.4162 18.3227 55.4316 17.6902 55.0781C17.0584 54.7245 16.6667 54.0574 16.6667 53.3333V10.6667L16.685 10.3984C16.7685 9.7807 17.1373 9.23132 17.6902 8.92189ZM20.6667 49.7526L49.5157 32L20.6667 14.2448V49.7526Z" fill="black" fill-opacity="0.54"/>
			</svg>
		</div>
	{% endif %}
	<!-- elementor-children-placeholder -->
</div>
