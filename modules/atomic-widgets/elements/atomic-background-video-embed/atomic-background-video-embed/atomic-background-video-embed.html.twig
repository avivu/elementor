{% set classes = ['e-con', 'e-atomic-element', base_styles.base] | merge(settings.classes | default([])) | join(' ') %}
{% set data_settings = {
	'source': settings.source,
	'autoplay': settings.autoplay,
	'mute': settings.mute,
	'loop': settings.loop,
	'start_time': settings.start_time,
	'end_time': settings.end_time,
	'play_on_mobile': settings.play_on_mobile,
	'privacy_mode': settings.privacy_mode,
	'fallback_image_url': settings.fallback_image.src | default(''),
} %}
<div class="{{ classes }} {{ editor_classes | default('') }}"
	data-id="{{ id }}"
	data-element_type="{{ type }}"
	data-e-type="{{ type }}"
	data-interaction-id="{{ interaction_id }}"
	data-interactions="{{ interactions | json_encode | e('html_attr') }}"
	data-settings="{{ data_settings | json_encode | e('html_attr') }}"
	{% if settings._cssid is defined and settings._cssid is not empty %}
		id="{{ settings._cssid | e('html_attr') }}"
	{% endif %}
	{% if settings.attributes is defined and settings.attributes is not empty %}
		{{ settings.attributes | raw }}
	{% endif %}
	{{ editor_attributes | default('') | raw }}>
	<!-- elementor-children-placeholder -->
</div>
