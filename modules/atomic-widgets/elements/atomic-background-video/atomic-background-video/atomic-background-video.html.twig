{%- set video_state = settings['video-state'] | default('default') -%}
{%- set classes_arr = ['e-con', 'e-atomic-element', base_styles.base, 'video-state-' ~ video_state] | merge(settings.classes | default([])) -%}
{%- if settings.show_controls is defined and not settings.show_controls -%}
    {%- set classes_arr = classes_arr | merge(['e-show-controls-false']) -%}
{%- endif -%}
{% set classes = classes_arr | join(' ') %}
<div class="{{ classes }} {{ editor_classes | default('') }}"
    data-id="{{ id }}"
    data-element_type="{{ type }}"
    data-e-type="{{ type }}"
    data-interaction-id="{{ interaction_id }}"
    data-interactions="{{ interactions | json_encode | e('html_attr') }}"
    style="display:flex; position:relative; overflow:hidden; width:100%; padding:0;"
    {% if settings._cssid is defined and settings._cssid is not empty %}
        id="{{ settings._cssid | e('html_attr') }}"
    {% endif %}
    {% if settings.attributes is defined and settings.attributes is not empty %}
        {{ settings.attributes | raw }}
    {% endif %}
    {{ editor_attributes | default('') | raw }}>
    {% if settings.source is defined and settings.source.url is not empty %}
        {%- set video_start_time = settings.start_time | default(null) -%}
        {%- set video_end_time = settings.end_time | default(null) -%}
        {%- if video_start_time is not empty -%}
            {%- set video_timings = '#t=' ~ video_start_time -%}
        {%- else -%}
            {%- set video_timings = '#t=0' -%}
        {%- endif -%}
        {%- if video_end_time is not empty and video_end_time > video_start_time -%}
            {%- set video_timings = video_timings ~ ',' ~ video_end_time -%}
        {%- endif -%}
        <video
            aria-hidden="true"
            style="position:absolute; top:0; left:0; right:0; bottom:0; width:100%; height:100%; object-fit:cover; z-index:0; pointer-events:none;"
            {% if settings.autoplay %}autoplay{% endif %}
            {% if settings.mute %}muted{% endif %}
            {% if settings.loop %}loop{% endif %}
            playsinline
        >
            <source src="{{ settings.source.url | e('full_url') ~ video_timings }}">
        </video>
    {% endif %}
    <!-- elementor-children-placeholder -->
</div>
